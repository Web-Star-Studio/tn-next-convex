{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false, // Pode ser ajustado para true para maior rigor
    "noImplicitAny": false,    // Pode ser ajustado para true
    "strictBindCallApply": false, // Pode ser ajustado para true
    "forceConsistentCasingInFileNames": false, // Pode ser ajustado para true
    "noFallthroughCasesInSwitch": false, // Pode ser ajustado para true
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": { // Adicionado para jest e typeorm cli
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
